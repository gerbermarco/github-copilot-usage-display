# Required: fine-grained PAT with user "Plan" permission set to read
GITHUB_TOKEN=your_token_here

# GitHub API and request settings
GITHUB_API_VERSION=2026-03-10
REQUEST_TIMEOUT_SECONDS=15
REQUEST_MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=1.5

# Usage card settings
COPILOT_LICENSE=Copilot Pro+
COPILOT_MONTHLY_QUOTA=1500
REFRESH_SECONDS=300

# Output settings
# OUTPUT_MODE can be console, eink, or both
OUTPUT_MODE=both

# E-ink display settings
EINK_DRIVER_MODULE=auto
EINK_ROTATION=0
GPIOZERO_PIN_FACTORY=lgpio